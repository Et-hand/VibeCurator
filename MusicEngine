def log_listening_event(
    conn: sqlite3.Connection,
    song_id: str,
    session_id: str,
    skipped: bool = False,
    replayed: bool = False,
    play_time_s: float = 0.0,
):
    conn.execute("""
        INSERT INTO listening_events
            (song_id, played_at, session_id, skipped, replayed, play_time_s)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (
        song_id,
        datetime.now().isoformat(),
        session_id,
        int(skipped),
        int(replayed),
        play_time_s,
    ))
    conn.commit()


def update_play_time(conn: sqlite3.Connection, song_id: str, play_time_s: float):
    """Update most recent listening event for a song with actual play time."""
    conn.execute("""
        UPDATE listening_events SET play_time_s = ?
        WHERE song_id = ? AND id = (
            SELECT id FROM listening_events WHERE song_id = ? ORDER BY id DESC LIMIT 1
        )
    """, (play_time_s, song_id, song_id))
    conn.commit()


def mark_skipped(conn: sqlite3.Connection, song_id: str):
    conn.execute("""
        UPDATE listening_events SET skipped = 1
        WHERE song_id = ? AND id = (
            SELECT id FROM listening_events WHERE song_id = ? ORDER BY id DESC LIMIT 1
        )
    """, (song_id, song_id))
    conn.commit()
