#  TRUESKILL RANKINGS  (per-genre + cross-genre)
# ─────────────────────────────────────────────────────────────────

TS_ENV = trueskill.TrueSkill(
    mu=25.0, sigma=8.333, beta=4.167,
    tau=0.083, draw_probability=0.1
)


def get_or_create_rating(
    conn: sqlite3.Connection,
    song_id: str,
    genre: str,
) -> trueskill.Rating:
    row = pd.read_sql(
        "SELECT mu, sigma FROM rankings WHERE song_id=? AND genre=?",
        conn, params=[song_id, genre]
    )
    if row.empty:
        return TS_ENV.create_rating()
    return TS_ENV.create_rating(mu=row.iloc[0]["mu"], sigma=row.iloc[0]["sigma"])


def save_rating(
    conn: sqlite3.Connection,
    song_id: str,
    genre: str,
    rating: trueskill.Rating,
):
    conn.execute("""
        INSERT INTO rankings (song_id, genre, mu, sigma, comparison_count, last_updated)
        VALUES (?, ?, ?, ?, 1, ?)
        ON CONFLICT(song_id) DO UPDATE SET
            genre             = excluded.genre,
            mu                = excluded.mu,
            sigma             = excluded.sigma,
            comparison_count  = comparison_count + 1,
            last_updated      = excluded.last_updated
    """, (song_id, genre, rating.mu, rating.sigma, datetime.now().isoformat()))
    conn.commit()


def record_comparison(
    conn: sqlite3.Connection,
    winner_id: str,
    loser_id: str,
    genre: str,
    draw: bool = False,
):
    wr = get_or_create_rating(conn, winner_id, genre)
    lr = get_or_create_rating(conn, loser_id,  genre)
    nw, nl = TS_ENV.rate_1vs1(wr, lr, drawn=draw)
    save_rating(conn, winner_id, genre, nw)
    save_rating(conn, loser_id,  genre, nl)
    conn.execute(
        "INSERT INTO comparisons (winner_id, loser_id, genre, timestamp) VALUES (?,?,?,?)",
        (winner_id, loser_id, genre, datetime.now().isoformat())
    )
    conn.commit()


def get_leaderboard(
    conn: sqlite3.Connection,
    genre: str | None = None,
) -> pd.DataFrame:
    """
    genre=None  → cross-genre leaderboard (weighted by play-time proportion).
    genre=str   → single-genre leaderboard.
    """
    if genre and genre != "__all__":
        df = pd.read_sql("""
            SELECT r.song_id, r.mu, r.sigma, r.comparison_count, r.genre,
                   s.name, s.artist, s.bpm, s.energy, s.camelot_key,
                   s.track_genre, s.album_cover_url,
                   (r.mu - 2*r.sigma) AS raw_score
            FROM rankings r
            JOIN songs s ON r.song_id = s.id
            WHERE r.genre = ?
            ORDER BY raw_score DESC
        """, conn, params=[genre])
    else:
        # Cross-genre: normalise each genre's scores to 0-1, then
        # weight by that genre's share of total play time.
        df = pd.read_sql("""
            SELECT r.song_id, r.mu, r.sigma, r.comparison_count, r.genre,
                   s.name, s.artist, s.bpm, s.energy, s.camelot_key,
                   s.track_genre, s.album_cover_url,
                   (r.mu - 2*r.sigma) AS raw_score
            FROM rankings r
            JOIN songs s ON r.song_id = s.id
            ORDER BY raw_score DESC
        """, conn)

        if df.empty:
            return df

        # Play-time per genre
        play_time = pd.read_sql("""
            SELECT s.track_genre, SUM(le.play_time_s) AS total_time
            FROM listening_events le
            JOIN songs s ON le.song_id = s.id
            GROUP BY s.track_genre
        """, conn)

        if play_time.empty or play_time["total_time"].sum() == 0:
            # Fallback: equal weight across genres
            genre_weight = {g: 1.0 for g in df["genre"].unique()}
        else:
            total = play_time["total_time"].sum()
            genre_weight = dict(
                zip(play_time["track_genre"],
                    play_time["total_time"] / total)
            )

        # Normalise raw_score within each genre then weight
        def norm_group(g):
            mn, mx = g["raw_score"].min(), g["raw_score"].max()
            g = g.copy()
            g["norm_score"] = (g["raw_score"] - mn) / (mx - mn + 1e-9) if mx > mn else 0.5
            gname = g["genre"].iloc[0]
            g["weighted_score"] = g["norm_score"] * genre_weight.get(gname, 1.0)
            return g

        df = df.groupby("genre", group_keys=False).apply(norm_group)
        df = df.sort_values("weighted_score", ascending=False)

    return _add_normalised_score(df)


def _add_normalised_score(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty:
        return df
    col = "weighted_score" if "weighted_score" in df.columns else "raw_score"
    mn, mx = df[col].min(), df[col].max()
    df = df.copy()
    df["score_0_10"] = (
        ((df[col] - mn) / (mx - mn + 1e-9) * 10).round(1)
        if mx > mn else 5.0
    )
    return df


def pick_comparison_partner(
    conn: sqlite3.Connection,
    song_id: str,
    genre: str,
) -> str | None:
    rating = get_or_create_rating(conn, song_id, genre)
    ranked = pd.read_sql("""
        SELECT song_id, mu FROM rankings
        WHERE song_id != ? AND genre = ? AND comparison_count > 0
    """, conn, params=[song_id, genre])

    if ranked.empty:
        fallback = pd.read_sql("""
            SELECT DISTINCT song_id FROM listening_events
            WHERE song_id != ?
            LIMIT 30
        """, conn, params=[song_id])
        return None if fallback.empty else fallback.sample(1).iloc[0]["song_id"]

    ranked["dist"] = abs(ranked["mu"] - rating.mu)
    top5 = ranked.nsmallest(5, "dist")
    return top5.sample(1).iloc[0]["song_id"]


# ─────────────────────────────────────────────────────────────────
#  ML SCORING  (content + ranking bias; collab when data is rich)
# ─────────────────────────────────────────────────────────────────

def get_content_scores(
    all_songs_scaled: pd.DataFrame,
    feature_cols: list[str],
    conn: sqlite3.Connection,
    candidate_ids: list[str],
    active_genres: list[str],
    top_n: int = 10,
) -> dict[str, float]:
    genre_clause = ""
    params: list = [top_n]
    if active_genres:
        ph = ",".join(["?"] * len(active_genres))
        genre_clause = f"AND s.track_genre IN ({ph})"
        params = [*active_genres, top_n]

    top = pd.read_sql(f"""
        SELECT r.song_id, (r.mu - 2*r.sigma) AS s
        FROM rankings r
        JOIN songs s ON r.song_id = s.id
        WHERE 1=1 {genre_clause}
        ORDER BY s DESC LIMIT ?
    """, conn, params=params)

    if top.empty:
        return {sid: 0.5 for sid in candidate_ids}

    ref = all_songs_scaled[all_songs_scaled["id"].isin(top["song_id"])][feature_cols]
    if ref.empty:
        return {sid: 0.5 for sid in candidate_ids}

    taste     = ref.values.mean(axis=0).reshape(1, -1)
    cands     = all_songs_scaled[all_songs_scaled["id"].isin(candidate_ids)][["id"] + feature_cols]
    sims      = cosine_similarity(taste, cands[feature_cols].values)[0]
    return dict(zip(cands["id"].tolist(), sims.tolist()))


def get_ranking_bias(
    all_songs_scaled: pd.DataFrame,
    feature_cols: list[str],
    conn: sqlite3.Connection,
    candidate_ids: list[str],
) -> dict[str, float]:
    rankings = pd.read_sql("""
        SELECT song_id, (mu - 2*sigma) AS score
        FROM rankings WHERE comparison_count >= 2
    """, conn)

    if rankings.empty:
        return {sid: 0.5 for sid in candidate_ids}

    rankings["normalized"] = (
        (rankings["score"] - rankings["score"].min()) /
        (rankings["score"].max() - rankings["score"].min() + 1e-9)
    )
    rf = all_songs_scaled[all_songs_scaled["id"].isin(rankings["song_id"])][["id"] + feature_cols]
    rf = rf.merge(rankings[["song_id", "normalized"]], left_on="id", right_on="song_id")
    cf = all_songs_scaled[all_songs_scaled["id"].isin(candidate_ids)][["id"] + feature_cols]

    if rf.empty or cf.empty:
        return {sid: 0.5 for sid in candidate_ids}

    sim_mat = cosine_similarity(cf[feature_cols].values, rf[feature_cols].values)
    scores  = sim_mat.dot(rf["normalized"].values) / (sim_mat.sum(axis=1) + 1e-9)
    return dict(zip(cf["id"].tolist(), scores.tolist()))


def get_hybrid_weight(conn: sqlite3.Connection) -> dict[str, float]:
    count = pd.read_sql("SELECT COUNT(*) AS n FROM rankings", conn).iloc[0]["n"]
    if count < 50:
        return {"content": 0.80, "collab": 0.15, "bias": 0.05}
    elif count < 200:
        t = (count - 50) / 150
        return {
            "content": 0.80 - 0.55 * t,
            "collab":  0.15 + 0.20 * t,
            "bias":    0.05 + 0.20 * t,
        }
    return {"content": 0.25, "collab": 0.50, "bias": 0.25}


def score_candidates(
    conn: sqlite3.Connection,
    all_songs_scaled: pd.DataFrame,
    feature_cols: list[str],
    candidates: pd.DataFrame,
    active_genres: list[str],
) -> pd.DataFrame:
    ids = candidates["id"].tolist()
    w   = get_hybrid_weight(conn)
    cs  = get_content_scores(all_songs_scaled, feature_cols, conn, ids, active_genres)
    bs  = get_ranking_bias(all_songs_scaled, feature_cols, conn, ids)
    candidates = candidates.copy()
    candidates["hybrid"] = candidates["id"].map(
        lambda s: w["content"] * cs.get(s, 0.5) +
                  (w["collab"] + w["bias"]) * bs.get(s, 0.5)
    )
    return candidates


# ─────────────────────────────────────────────────────────────────
#  NEXT SONG SELECTOR
# ─────────────────────────────────────────────────────────────────

def get_next_song(
    conn: sqlite3.Connection,
    all_songs_scaled: pd.DataFrame,
    feature_cols: list[str],
    current_song_id: str,
    active_genres: list[str],
    recently_played: list[str],
    recently_played_artists: list[str],
    energy_direction: str = "maintain",
) -> pd.Series | None:

    current = pd.read_sql(
        "SELECT * FROM songs WHERE id=?", conn, params=[current_song_id]
    )
    if current.empty:
        return None
    current = current.iloc[0]

    cands = get_candidates(conn, current, active_genres)

    if recently_played:
        cands = cands[~cands["id"].isin(recently_played)]
    if recently_played_artists:
        cands = cands[~cands["artist"].isin(recently_played_artists)]

    # Progressive fallbacks
    if cands.empty:
        cands = get_candidates(conn, current, active_genres, bpm_range=15)
        if recently_played:
            cands = cands[~cands["id"].isin(recently_played)]
    if cands.empty:
        cands = get_candidates(conn, current, active_genres, bpm_range=20)
    if cands.empty:
        return None

    cands = score_candidates(conn, all_songs_scaled, feature_cols, cands, active_genres)

    if energy_direction == "build":
        top  = cands.nlargest(20, "hybrid")
        pick = top.loc[top["energy"].idxmax()]
    elif energy_direction == "cool":
        top  = cands.nlargest(20, "hybrid")
        pick = top.loc[top["energy"].idxmin()]
    else:
        pick = cands.nlargest(1, "hybrid").iloc[0]

    return pick


def get_recommendations(
    conn: sqlite3.Connection,
    all_songs_scaled: pd.DataFrame,
    feature_cols: list[str],
    active_genres: list[str],
    n: int = 15,
) -> pd.DataFrame:
    genre_clause = ""
    params: list = [500]
    if active_genres:
        ph = ",".join(["?"] * len(active_genres))
        genre_clause = f"WHERE track_genre IN ({ph})"
        params = [*active_genres, 500]

    cands = pd.read_sql(
        f"SELECT id FROM songs {genre_clause} ORDER BY RANDOM() LIMIT ?",
        conn, params=params
    )
    if cands.empty:
        return pd.DataFrame()

    all_songs = pd.read_sql("SELECT * FROM songs", conn)
    ids = cands["id"].tolist()
    w   = get_hybrid_weight(conn)
    cs  = get_content_scores(all_songs_scaled, feature_cols, conn, ids, active_genres)
    bs  = get_ranking_bias(all_songs_scaled, feature_cols, conn, ids)

    results = pd.DataFrame([{
        "song_id": sid,
        "hybrid":  w["content"] * cs.get(sid, 0.5) + (w["collab"] + w["bias"]) * bs.get(sid, 0.5)
    } for sid in ids]).sort_values("hybrid", ascending=False).head(n)

    return results.merge(
        all_songs[["id", "name", "artist", "bpm", "energy", "camelot_key",
                   "track_genre", "album_cover_url"]],
        left_on="song_id", right_on="id"
    )


