def get_connection() -> sqlite3.Connection:
    conn = sqlite3.connect(DB_PATH, check_same_thread=False)
    conn.row_factory = sqlite3.Row
    return conn

def build_spotify_oauth() -> SpotifyOAuth:
    return SpotifyOAuth(
        client_id=os.environ.get("SPOTIPY_CLIENT_ID", ""),
        client_secret=os.environ.get("SPOTIPY_CLIENT_SECRET", ""),
        redirect_uri=os.environ.get("SPOTIPY_REDIRECT_URI", "http://127.0.0.1:8501"),
        scope=SPOTIFY_SCOPES,
        cache_path=".spotify_cache",
        open_browser=False,
    )


def init_db(conn: sqlite3.Connection):
    """Create all tables if they don't exist."""
    conn.executescript("""
        CREATE TABLE IF NOT EXISTS songs (
            id              TEXT PRIMARY KEY,
            name            TEXT,
            artist          TEXT,
            bpm             REAL,
            energy          REAL,
            danceability    REAL,
            valence         REAL,
            loudness        REAL,
            instrumentalness REAL,
            key             INTEGER,
            mode            INTEGER,
            camelot_key     TEXT,
            track_genre     TEXT,
            album_cover_url TEXT
        );

        CREATE TABLE IF NOT EXISTS listening_events (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            song_id     TEXT,
            played_at   TEXT,
            session_id  TEXT,
            skipped     INTEGER DEFAULT 0,
            replayed    INTEGER DEFAULT 0,
            play_time_s REAL DEFAULT 0
        );

        CREATE TABLE IF NOT EXISTS rankings (
            id               INTEGER PRIMARY KEY AUTOINCREMENT,
            song_id          TEXT UNIQUE,
            genre            TEXT,
            mu               REAL DEFAULT 25.0,
            sigma            REAL DEFAULT 8.333,
            comparison_count INTEGER DEFAULT 0,
            last_updated     TEXT
        );

        CREATE TABLE IF NOT EXISTS comparisons (
            id         INTEGER PRIMARY KEY AUTOINCREMENT,
            winner_id  TEXT,
            loser_id   TEXT,
            genre      TEXT,
            timestamp  TEXT
        );
    """)
    conn.commit()


def load_songs_df(conn: sqlite3.Connection) -> pd.DataFrame:
    return pd.read_sql("SELECT * FROM songs", conn)


def get_available_genres(conn: sqlite3.Connection) -> list[str]:
    """Return all distinct genres present in the songs table."""
    result = pd.read_sql(
        "SELECT DISTINCT track_genre FROM songs WHERE track_genre IS NOT NULL ORDER BY track_genre",
        conn
    )
    return sorted(result["track_genre"].dropna().tolist())


def filter_songs_by_genres(
    conn: sqlite3.Connection,
    genres: list[str]
) -> pd.DataFrame:
    if not genres:
        return pd.read_sql("SELECT * FROM songs", conn)
    placeholders = ",".join(["?"] * len(genres))
    return pd.read_sql(
        f"SELECT * FROM songs WHERE track_genre IN ({placeholders})",
        conn, params=genres
    )


# ─────────────────────────────────────────────────────────────────
#  SCALER (fit once on all songs)
# ─────────────────────────────────────────────────────────────────

def build_scaler(songs_df: pd.DataFrame):
    scaler = MinMaxScaler()
    cols = [c for c in CONTENT_FEATURES if c in songs_df.columns]
    scaled = songs_df.copy()
    scaled[cols] = scaler.fit_transform(songs_df[cols].fillna(0))
    return scaler, scaled, cols


