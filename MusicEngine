#  CAMELOT / SEQUENCER HELPERS
# ─────────────────────────────────────────────────────────────────

def camelot_from_key_mode(key: int, mode: int) -> str:
    return CAMELOT_MAP.get((int(key), int(mode)), "unknown")


def get_compatible_camelot_keys(camelot_key: str) -> list[str]:
    if not camelot_key or camelot_key == "unknown":
        return []
    number   = int(camelot_key[:-1])
    letter   = camelot_key[-1]
    opposite = "A" if letter == "B" else "B"
    prev_n   = 12 if number == 1  else number - 1
    next_n   = 1  if number == 12 else number + 1
    return [
        f"{prev_n}{letter}",
        f"{number}{letter}",
        f"{next_n}{letter}",
        f"{number}{opposite}",
    ]


def get_candidates(
    conn: sqlite3.Connection,
    current_song: pd.Series,
    active_genres: list[str],
    bpm_range: int = 8,
    limit: int = 150,
) -> pd.DataFrame:
    keys = get_compatible_camelot_keys(current_song.get("camelot_key", ""))
    genre_clause = ""
    genre_params: list = []
    if active_genres:
        ph = ",".join(["?"] * len(active_genres))
        genre_clause = f"AND track_genre IN ({ph})"
        genre_params = list(active_genres)

    if keys:
        ph = ",".join(["?"] * len(keys))
        q = f"""
            SELECT * FROM songs
            WHERE bpm BETWEEN ? AND ?
            AND camelot_key IN ({ph})
            AND id != ?
            {genre_clause}
            LIMIT {limit}
        """
        params = [
            current_song["bpm"] - bpm_range,
            current_song["bpm"] + bpm_range,
            *keys,
            current_song["id"],
            *genre_params,
        ]
    else:
        q = f"""
            SELECT * FROM songs
            WHERE bpm BETWEEN ? AND ?
            AND id != ?
            {genre_clause}
            LIMIT {limit}
        """
        params = [
            current_song["bpm"] - bpm_range,
            current_song["bpm"] + bpm_range,
            current_song["id"],
            *genre_params,
        ]

    df = pd.read_sql(q, conn, params=params)
    if df.empty and bpm_range < 20:
        return get_candidates(conn, current_song, active_genres, bpm_range + 6, limit)
    return df


