def get_spotify_client() -> spotipy.Spotify | None:
    """Return an authenticated Spotify client, or None if not authed."""
    try:
        oauth = build_spotify_oauth()
        token_info = oauth.get_cached_token()
        if token_info:
            return spotipy.Spotify(auth=token_info["access_token"])
        return None
    except Exception:
        return None


def get_auth_url() -> str:
    return build_spotify_oauth().get_authorize_url()


def exchange_code_for_token(code: str) -> dict | None:
    try:
        oauth = build_spotify_oauth()
        return oauth.get_access_token(code, as_dict=True)
    except Exception:
        return None


def get_active_device(sp: spotipy.Spotify) -> str | None:
    try:
        devices = sp.devices()
        if not devices["devices"]:
            return None
        for d in devices["devices"]:
            if d["is_active"]:
                return d["id"]
        return devices["devices"][0]["id"]
    except Exception:
        return None


def search_and_get_track(sp: spotipy.Spotify, song_name: str, artist: str) -> dict | None:
    """Search Spotify for a track. Returns full track object or None."""
    try:
        results = sp.search(
            q=f"track:{song_name} artist:{artist}", type="track", limit=1
        )
        items = results["tracks"]["items"]
        if not items:
            results = sp.search(
                q=f"{song_name} {artist}", type="track", limit=1
            )
            items = results["tracks"]["items"]
        return items[0] if items else None
    except Exception:
        return None


def play_song_on_spotify(
    sp: spotipy.Spotify,
    song_name: str,
    artist: str,
) -> tuple[str | None, str | None, str]:
    """
    Play a song on Spotify.
    Returns (track_uri, album_cover_url, status_message).
    """
    device_id = get_active_device(sp)
    if device_id is None:
        return None, None, "NO_DEVICE"

    track = search_and_get_track(sp, song_name, artist)
    if track is None:
        return None, None, f"NOT_FOUND"

    uri = track["uri"]
    album_cover = None
    images = track.get("album", {}).get("images", [])
    if images:
        # Pick medium size (index 1) if available, else largest
        album_cover = images[1]["url"] if len(images) > 1 else images[0]["url"]

    try:
        sp.start_playback(device_id=device_id, uris=[uri])
        return uri, album_cover, "OK"
    except spotipy.exceptions.SpotifyException as e:
        if "Premium" in str(e):
            return None, None, "NEEDS_PREMIUM"
        return None, None, f"ERROR: {e}"


def pause_spotify(sp: spotipy.Spotify):
    try:
        sp.pause_playback()
    except Exception:
        pass


def set_volume(sp: spotipy.Spotify, level: int):
    try:
        sp.volume(max(0, min(100, level)))
    except Exception:
        pass


def get_currently_playing(sp: spotipy.Spotify) -> dict | None:
    """Return currently playing track info from Spotify."""
    try:
        result = sp.currently_playing()
        if result and result.get("item"):
            item = result["item"]
            images = item.get("album", {}).get("images", [])
            cover = images[1]["url"] if len(images) > 1 else (images[0]["url"] if images else None)
            return {
                "name":      item["name"],
                "artist":    item["artists"][0]["name"],
                "cover_url": cover,
                "progress":  result.get("progress_ms", 0),
                "duration":  item["duration_ms"],
                "is_playing": result.get("is_playing", False),
            }
    except Exception:
        pass
    return None


